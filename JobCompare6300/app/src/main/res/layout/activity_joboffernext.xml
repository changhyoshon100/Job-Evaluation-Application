<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="1dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="1dp"
        android:layout_marginBottom="1dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textViewText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I would like to ..."
            android:textAlignment="textStart"
            android:textSize="48sp" />

        <Button
            android:id="@+id/buttonEnterOffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter another job offer" />

        <Button
            android:id="@+id/buttonReturnToMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Return to main manu" />

        <Button
            android:id="@+id/buttonCompareWithCurrent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compare with current job" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>